{
  "schemaVersion": 1,
  "id": "acousticsystem",
  "version": "${version}",
  "name": "AcousticSystem",
  "description": "Continuously recalculated real-time block-aware sound propagation.",
  "icon": "assets/acousticsystem/icon.png",
  "authors": ["macaroon"],
  "license": "All-Rights-Reserved",
  "environment": "client",
  "entrypoints": {
    "main": ["org.macaroon.acousticsystem.AcousticSystem"],
    "client": ["org.macaroon.acousticsystem.client.AcousticSystemClient"]
  },
  "mixins": [
    {
      "config": "acousticsystem.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": "~${minecraft_version}",
    "java": ">=${java_minimum}",
    "fabric-api": ">=${fabric_api_minimum}"
  }
}
